@model LeaveManagementSystem.Web.Data.LeaveType

@{
    ViewData["Title"] = "Create Leave Type";
}

<h1>Create Leave Type</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create"> @* method will be POST as default *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label> @* asp-for="Name": binding to the Name property of LeaveType model *@
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <label asp-for="NumberOfDays" class="control-label"></label>
                <input asp-for="NumberOfDays" class="form-control" />
                <span asp-validation-for="NumberOfDays" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-primary">Back to List</a> @* asp-action: specifies the action method to link to. e.g. Index() in LeaveTypesController.cs *@
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
